# ========== JARVIS env template ==========
# Copy to .env.local in apps/web/ (or the root if using a root .env loader).
# Never commit the real .env file — .gitignore blocks it.

# ---- Anthropic (the brain) ----
ANTHROPIC_API_KEY=sk-ant-...

# ---- Supabase (DB, auth, realtime, storage) ----
# Create a project at https://supabase.com, choose region = London (eu-west-2).
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
# Service role key — SERVER ONLY. Never expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ---- Google OAuth (Gmail + Calendar scopes) ----
# Configure in Supabase Auth → Providers → Google, and also here for direct API calls.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ---- Voice stack (Phase 2) ----
# Speech-to-text (default = Groq Whisper, cheapest).
GROQ_API_KEY=
# Fallback streaming STT.
DEEPGRAM_API_KEY=
# Text-to-speech — premium voices + cloning.
ELEVENLABS_API_KEY=
# Wake word — free hobby tier, upgrade before commercial launch.
NEXT_PUBLIC_PICOVOICE_ACCESS_KEY=

# ---- Embeddings (for semantic memory) ----
# Voyage-3 is cheapest; swap to Anthropic embeddings when available.
VOYAGE_API_KEY=

# ---- App config ----
NEXT_PUBLIC_APP_URL=http://localhost:3030
